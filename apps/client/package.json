{
  "name": "collab-code-client",
  "version": "1.0.0",
  "description": "Electron desktop client for CollabCode platform",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"react-scripts start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-eject": "react-scripts eject",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run react-build && electron-builder",
    "build": "npm run react-build",
    "start": "npm run electron-dev"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.5.0",
    "axios": "^1.5.0",
    "electron-is-dev": "^3.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.292.0",
    "peerjs": "^1.4.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^2.10.0",
    "socket.io-client": "^4.6.1",
    "tailwindcss": "^3.3.3",
    "yjs": "^13.6.8",
    "y-protocols": "^1.0.6",
    "lib0": "^0.2.94"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "electron": "^26.3.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.31",
    "react-scripts": "5.0.1",
    "wait-on": "^7.0.1"
  },
  "build": {
    "extends": null,
    "productName": "CollabCode",
    "appId": "com.collabcode.app",
    "files": [
      "public/electron.js",
      "public/preload.js",
      "public/electron-starter.js",
      "build/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
